{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KagiBox",
  "version": "0.1.0",
  "identifier": "com.kagibox",
  "build": {
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "createUpdaterArtifacts": true,
    "windows": {
      "nsis": {
        "languages": ["Japanese", "English"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Irony-s9c/kagibox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJBMTlGQTYxQzFGNDE2RTYKUldUbUZ2VEJZZm9aS3FQdEI5UU1GWVprdWxOWVVzQ244NGtZRUl0OGJqdGxMbFlybWxHUmtiN3IK",
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "KagiBox",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "label": "main"
      }
    ],
    "security": {
      "csp": null
    }
  }
}
